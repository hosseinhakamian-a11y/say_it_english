# Database Connection
# Get this from Supabase: Project Settings > Database > Connection String > URI
# Make sure to enable "Use connection pooling" and replace [YOUR-PASSWORD] with your actual password
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres

# Environment
NODE_ENV=development

# AvalAI (OpenAI-compatible gateway for GPT/Claude/Gemini) — used by /api/chat
# Get your key from https://avalai.ir dashboard. Put the real value in .env.local, never here.
AVALAI_API_KEY=
# Optional overrides — defaults are https://api.avalai.ir/v1 and gpt-4o-mini
# AVALAI_BASE_URL=https://api.avalai.ir/v1
# AVALAI_MODEL=gpt-4o-mini

# ZarinPal (real payment gateway) — used by /api/payment/request and /api/payment/verify
# Get your Merchant ID from https://next.zarinpal.com dashboard. Put the real value in .env.local, never here.
ZARINPAL_MERCHANT_ID=
# Set to "true" to use ZarinPal's sandbox (test) environment instead of production
# ZARINPAL_SANDBOX=true

# Upstash Redis (optional) — makes rate limiting work correctly across serverless invocations.
# Without these, rate limiting silently falls back to an in-memory Map that only works per warm instance.
# Get both from your Upstash Redis database's REST API tab: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
